# ==============================================================================
# ENTERPRISE LEVEL GITIGNORE TEMPLATE
# ==============================================================================
# This is a comprehensive, production-ready .gitignore file designed for enterprise 
# environments. It covers operating systems, popular IDEs, common programming 
# languages, build tools, package managers, database files, and security/secret keys.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. SECURITY & SENSITIVE DATA (CRITICAL)
# ------------------------------------------------------------------------------
# Never commit credentials, secrets, private keys, or local environment configurations.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
*.pem
*.key
*.pub
*.cert
*.pfx
*.p12
*.keystore
*.jks
*.gpg
secrets.json
credentials.json
.mcp.json
/config/jwt/
/config/secrets/

# ------------------------------------------------------------------------------
# 2. OPERATING SYSTEM SPECIFIC
# ------------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.lnk
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk
[Dd]esktop.ini
$RECYCLE.BIN/

# Linux / Unix
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ------------------------------------------------------------------------------
# 3. EDITORS & IDEs
# ------------------------------------------------------------------------------
# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/code-workspace
.code-workspaces
*.code-workspace

# JetBrains (IntelliJ, WebStorm, PyCharm, CLion, Rider, GoLand, etc.)
.idea/
*.iws
*.iml
*.ipr
out/

# Eclipse
.metadata/
.classpath
.project
.settings/
*.launch
.factorypath

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.netbeans_derby/

# Sublime Text / TextMate
*.sublime-project
*.sublime-workspace
.tmbundle/
*.tmproj

# Vim & Emacs
.*.sw[a-z]
*.un~
Session.vim
.netrwhist
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
elpa/
*.elc
auto-save-list/
.dir-locals.el

# Xcode / Mac Development
build/
DerivedData/
*.placeholder
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
xcuserdata/
*.xccheckout
*.moved-aside
*.xcuserstate
*.xsyncrefs
## Obj-C/Swift specific
*.ipa
*.dSYM.zip
*.dSYM

# ------------------------------------------------------------------------------
# 4. PACKAGE MANAGERS & LANGUAGE DEPENDENCIES
# ------------------------------------------------------------------------------

pom.xml.releaseBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.gradle/
/build/
!gradle/wrapper/gradle-wrapper.jar
.gradletasknamecache

# Go
/bin/
/pkg/
/src/
*.out
*.exe
*.test
*.prof

# Rust
/target/
Cargo.lock

# Ruby
/assets/stylesheets/compiled/
.bundle/
/db/*.sqlite3
/db/*.sqlite3-journal
/db/*.sqlite3-shm
/db/*.sqlite3-wal
/log/*.log
/tmp/
.yardoc/
_yardoc/
doc/
tags

